# LocalAI stack — copy to /opt/homebrew/etc/Caddyfile.localai.conf on M2 Max
# Generate certs: tailscale cert iu-mac-book.dinosaur-sole.ts.net
iu-mac-book.dinosaur-sole.ts.net {
	tls /opt/homebrew/etc/certs/iu-mac-book.dinosaur-sole.ts.net.crt /opt/homebrew/etc/certs/iu-mac-book.dinosaur-sole.ts.net.key

	handle /v1/chat/* {
		reverse_proxy localhost:11434
	}
	handle /v1/models* {
		reverse_proxy localhost:11434
	}
	handle /v1/audio/speech* {
		reverse_proxy localhost:8000
	}
	handle /v1/audio/transcriptions* {
		reverse_proxy localhost:8000 {
			header_down Content-Type "application/json"
		}
	}
}
