# Claude Code with auto workspace detection + queue /clear restart loop
c() {
  local restart_marker="$HOME/.claude/.queue-restart"
  local claude_args=("$@")

  while true; do
    if [[ "$PWD" == "$HOME/SourceRoot"* ]]; then
      ENABLE_TOOL_SEARCH=true claude --dangerously-skip-permissions --chrome --plugin-dir ~/SourceRoot/.claude "${claude_args[@]}"
    elif [[ "$PWD" == "$HOME/IuRoot"* ]]; then
      ENABLE_TOOL_SEARCH=true claude --dangerously-skip-permissions --chrome --plugin-dir "$(git rev-parse --show-toplevel 2>/dev/null || echo '.')/.claude" "${claude_args[@]}"
    else
      ENABLE_TOOL_SEARCH=true claude --dangerously-skip-permissions --chrome "${claude_args[@]}"
    fi

    # Queue /clear: hook wrote next task to marker — restart with fresh context
    if [[ -f "$restart_marker" ]]; then
      local next_task
      next_task=$(<"$restart_marker")
      rm -f "$restart_marker"
      if [[ -n "$next_task" ]]; then
        echo "\n[cq] Fresh context — continuing queue\n"
        claude_args=("$next_task")
        continue
      fi
    fi
    break
  done
}

