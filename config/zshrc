# OPENSPEC:START
# OpenSpec shell completions — must run before any compdef calls
fpath=("/Users/johannes.krumm/.zsh/completions" $fpath)
autoload -Uz compinit
if [[ -n ~/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi
# OPENSPEC:END

# Modules — ~/SourceRoot/claude-local/config/zsh/ symlinked to ~/.zsh/conf.d/
# Loaded alphabetically; ordering is safe (functions resolve env at call time).
#
#   ai.zsh          ai/fix — LLM shell helpers via Claude Haiku
#   aliases.zsh     sz, gback, homelab, vps, cq, zed, npmplease, iu
#   claude.zsh      c() — workspace-aware Claude Code launcher + cqueue restart
#   git.zsh         nb() — smart branch switch/create; rebuild-vps
#   keybindings.zsh Warp-like editing: Ctrl+A/E, Ctrl+W/U/K, Option+arrows
#   path.zsh        PATH, homebrew, fnm, deno, npm globals
#   secrets.zsh     1Password: OP token, ANTHROPIC_API_KEY, ANTHROPIC_BASE_URL
#   tools.zsh       zoxide (j/ji), fzf (Ctrl+R/T), wtp, bun

for f in ~/.zsh/conf.d/*.zsh(N); do source "$f"; done
