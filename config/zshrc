#===========
# GIT WORKTREE MANAGEMENT (via wtp)
# =========
# wtp (git worktree manager, cached)
_wtp_cache="$HOME/.cache/zsh/wtp-init.zsh"
if [[ ! -f "$_wtp_cache" || $(command -v wtp) -nt "$_wtp_cache" ]]; then
  mkdir -p "${_wtp_cache:h}"
  wtp shell-init zsh >| "$_wtp_cache"
fi
source "$_wtp_cache"

