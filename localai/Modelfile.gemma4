# Gemma 4 26B-A4B — Optimized for Hermes Agent on M2 Max 32GB
#
# Usage:
#   ollama create gemma4-agent -f localai/Modelfile.gemma4
#   ollama run gemma4-agent
#
# Memory: ~18GB model + ~6GB KV cache at 128K = ~24GB
# Keep-alive: controlled by OLLAMA_KEEP_ALIVE env var in launchd plist

FROM gemma4:26b

# 128K context for Hermes Agent agentic workflows
PARAMETER num_ctx 131072

# Temperature — balanced for conversation + tool use
PARAMETER temperature 0.7
